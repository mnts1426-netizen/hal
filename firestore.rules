rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة مساعدة لجلب بيانات المستخدم الحالي (الذي قام بتسجيل الدخول)
    function caller() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // دوال التحقق من المناصب
    function isAdmin() { return request.auth != null && caller().role == 'admin'; }
    function isSupervisor() { return request.auth != null && caller().role == 'supervisor'; }
    function isTeacher() { return request.auth != null && caller().role == 'teacher'; }

    // دوال للتحقق من نطاق الصلاحيات (Data Scope)
    function isTeacherOf(circleId) { return isTeacher() && caller().circleId == circleId; }
    function isSupervisorOf(circleId) { return isSupervisor() && (circleId in caller().managedCircles); }

    // ==========================================
    // 1. صلاحيات المستخدمين (المدراء، المشرفين، المعلمين)
    // ==========================================
    match /users/{userId} {
      allow read: if request.auth != null; // الجميع يمكنه قراءة الأسماء للقائمة المنسدلة
      allow write: if isAdmin(); // الإدارة العليا فقط من تضيف وتحذف المستخدمين
    }

    // ==========================================
    // 2. صلاحيات الطلاب
    // ==========================================
    match /students/{studentId} {
      // القراءة: للمدير، أو المشرف على حلقة الطالب، أو معلم حلقة الطالب
      allow read: if isAdmin() || 
                  (isSupervisor() && resource.data.circleId in caller().managedCircles) || 
                  (isTeacher() && resource.data.circleId == caller().circleId);
      
      // التعديل والإضافة: للمدير، وللمشرف (فقط في نطاق حلقاته)
      allow write: if isAdmin() || 
                   (isSupervisor() && resource.data.circleId in caller().managedCircles);
      
      allow create: if isAdmin() || 
                    (isSupervisor() && request.resource.data.circleId in caller().managedCircles);
    }

    // ==========================================
    // 3. صلاحيات الحضور والتسميع
    // ==========================================
    match /attendance/{docId} {
      // المعلم يمكنه تسجيل وتعديل حضور طلابه فقط، والمشرف يراقب حلقاته
      allow read: if isAdmin() || isSupervisorOf(resource.data.circleId) || isTeacherOf(resource.data.circleId);
      allow create: if isAdmin() || isSupervisorOf(request.resource.data.circleId) || isTeacherOf(request.resource.data.circleId);
      allow update: if isAdmin() || isSupervisorOf(resource.data.circleId) || 
                    (isTeacherOf(resource.data.circleId) && request.resource.data.date == resource.data.date); // المعلم يعدل في نفس اليوم فقط
      allow delete: if isAdmin() || isSupervisorOf(resource.data.circleId);
    }

    match /recitations/{docId} {
      allow read: if isAdmin() || isSupervisorOf(resource.data.circleId) || isTeacherOf(resource.data.circleId);
      allow create, update: if isAdmin() || isSupervisorOf(request.resource.data.circleId) || isTeacherOf(request.resource.data.circleId);
      allow delete: if isAdmin() || isSupervisorOf(resource.data.circleId);
    }

    // ==========================================
    // 4. سجل العمليات (Audit Logs)
    // ==========================================
    match /audit_logs/{logId} {
      allow read: if isAdmin() || isSupervisor(); // المشرف يرى السجلات، المدير يرى كل شيء
      allow create: if request.auth != null; // النظام يسجل عمليات الجميع تلقائياً
      allow update, delete: if false; // السجلات غير قابلة للحذف والتعديل نهائياً (للموثوقية)
    }

    // حظر افتراضي لأي مسار غير معرّف
    match /{document=**} {
      allow read, write: if false;
    }
  }
}